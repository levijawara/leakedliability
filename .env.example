# Copy to .env and fill in. Never commit .env.
# Used by: local scripts (scripts/*.ts), and by Vite for dev (VITE_* only).

# --- Required for admin scripts (read/write from Cursor/Claude-run scripts) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_supabase_dashboard

# --- Required for app (dev and production build) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_from_supabase_dashboard

# --- Optional (for scripts that need them) ---
# VITE_STRIPE_PUBLISHABLE_KEY=pk_...
# PUBLIC_SITE_URL=https://your-app.vercel.app

# --- For run-backfill-contacts.ts (Backfill Unsaved Contacts) ---
# ADMIN_EMAIL=your_admin_email@example.com
# ADMIN_PASSWORD=your_admin_password
