# Copy to .env.local (app) and/or .env (scripts). Never commit real secrets.
# Used by:
# - Vite app runtime/build (`VITE_*`)
# - local scripts in `scripts/*.ts` (non-VITE vars)

# --- Required for admin/local scripts ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_supabase_dashboard

# --- Required for app (dev + production build) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_from_supabase_dashboard
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_publishable_key

# --- Optional app/script values ---
# PUBLIC_SITE_URL=https://your-app.vercel.app

# --- For run-backfill-contacts.ts (Backfill Unsaved Contacts) ---
# ADMIN_EMAIL=your_admin_email@example.com
# ADMIN_PASSWORD=your_admin_password
